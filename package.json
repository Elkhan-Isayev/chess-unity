{
  "name": "chess-lan",
  "version": "1.0.0",
  "description": "Offline LAN multiplayer chess you play in the browser — host on one machine, share a link, others join as players or spectators. No internet required.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/room.test.js",
    "test:e2e": "node test/e2e.mjs"
  },
  "keywords": [
    "chess",
    "multiplayer",
    "lan",
    "offline",
    "websocket",
    "spectator"
  ],
  "author": "Elkhan Isayev",
  "license": "MIT",
  "dependencies": {
    "chess.js": "^1.0.0",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "puppeteer": "^23.0.0"
  }
}
